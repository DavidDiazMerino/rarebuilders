{
  "framework": "vite",
  "functions": {
    "api/capabilities.ts": {
      "maxDuration": 30
    },
    "api/discover/**/*.ts": {
      "maxDuration": 30
    },
    "api/github/**/*.ts": {
      "maxDuration": 30
    },
    "api/opportunities/**/*.ts": {
      "maxDuration": 30
    },
    "api/profile/**/*.ts": {
      "maxDuration": 30
    },
    "api/source/**/*.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs",
      "maxDuration": 30
    },
    "api/strategies/**/*.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
