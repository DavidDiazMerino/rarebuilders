# Required for live GPT-5.6 analysis. Never expose this through a VITE_ variable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Required for AI cache, per-IP limits and the hard global operation ceiling.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AI_GLOBAL_OPERATION_LIMIT=40

# Optional. A fine-grained token with public-repository read access stabilizes
# GitHub REST rate limits. The connector also works unauthenticated.
GITHUB_TOKEN=
