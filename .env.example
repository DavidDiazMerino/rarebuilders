# Required for live GPT-5.6 analysis. Never expose this through a VITE_ variable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Required for AI cache, per-IP limits and the hard global operation ceiling.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel Marketplace's equivalent names are also supported automatically:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
AI_GLOBAL_OPERATION_LIMIT=40
AI_OWNER_GLOBAL_OPERATION_LIMIT=150

# Optional personal quota access. Store only the lowercase SHA-256 digest of
# the private code, never the code itself.
OWNER_ACCESS_CODE_SHA256=

# Optional. A fine-grained token with public-repository read access stabilizes
# GitHub REST rate limits. The connector also works unauthenticated.
GITHUB_TOKEN=

# Optional but required to activate the Kaggle competition connector.
# Prefer the current token. Username/key remain as a legacy fallback.
KAGGLE_API_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=
